# Copy to .env.local and fill in. Without these the site still runs — it just
# serves the built-in content in lib/data.js and /studio shows setup steps.

# From https://sanity.io/manage, or written for you by `npx sanity init --env`.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Only needed by `npm run seed`. Create at sanity.io/manage -> API -> Tokens
# with Editor permission. Never commit this value.
SANITY_API_WRITE_TOKEN=
